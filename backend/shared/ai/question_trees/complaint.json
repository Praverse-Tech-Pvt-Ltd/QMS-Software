{
  "module": "complaint",
  "questions": [
    {
      "id": "q1",
      "text": "Who reported this complaint?",
      "field": "complainant_type",
      "type": "choice",
      "options": ["Customer / Patient", "Healthcare Professional", "Distributor", "Regulatory Authority", "Internal"],
      "required": true,
      "next": "q2"
    },
    {
      "id": "q2",
      "text": "Which product and batch/lot number is involved?",
      "field": "product_batch",
      "type": "text",
      "required": true,
      "next": "q3"
    },
    {
      "id": "q3",
      "text": "What is the nature of the complaint?",
      "field": "complaint_nature",
      "type": "choice",
      "options": ["Product quality defect", "Adverse drug reaction", "Packaging / labelling issue", "Efficacy complaint", "Delivery / supply issue"],
      "required": true,
      "branches": {
        "Adverse drug reaction": "q3b"
      },
      "next": "q4"
    },
    {
      "id": "q3b",
      "text": "Was the adverse reaction serious (hospitalisation, death, life-threatening)?",
      "field": "serious_adr",
      "type": "choice",
      "options": ["Yes", "No"],
      "required": true,
      "next": "q4"
    },
    {
      "id": "q4",
      "text": "Is a retained / reference sample available for investigation?",
      "field": "sample_available",
      "type": "choice",
      "options": ["Yes", "No", "Partially"],
      "required": true,
      "next": "q5"
    },
    {
      "id": "q5",
      "text": "Has similar complaint been received for this product before?",
      "field": "repeat_complaint",
      "type": "choice",
      "options": ["Yes", "No", "Unknown"],
      "required": true,
      "next": null
    }
  ]
}
